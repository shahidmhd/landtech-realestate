NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Mongo
MONGODB_URI=mongodb://localhost:27017/luxe_estates

# Auth
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Mail (optional — used by inquiry notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Luxe Estates <no-reply@example.com>"
MAIL_TO_LEADS=leads@example.com

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "cloudinary": "^2.5.1",
    "multer": "^1.4.5-lts.1",
